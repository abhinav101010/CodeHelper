{
  "For Loop": {
    "prefix": ["for", "fori"],
    "body": ["for (let ${1:i} = 0; $1 < ${2:n}; $1++) {", "\t${0}", "}"],
    "description": "For loop"
  },
  "For-of Loop": {
    "prefix": ["forof", "foro"],
    "body": ["for (const ${1:item} of ${2:iterable}) {", "\t${0}", "}"],
    "description": "For...of loop"
  },
  "For-in Loop": {
    "prefix": ["forin", "fori"],
    "body": ["for (const ${1:key} in ${2:obj}) {", "\t${0}", "}"],
    "description": "For...in loop"
  },
  "While Loop": {
    "prefix": ["while"],
    "body": ["while (${1:condition}) {", "\t${0}", "}"],
    "description": "While loop"
  },
  "Do-While Loop": {
    "prefix": ["dowhile", "do"],
    "body": ["do {", "\t${0}", "} while (${1:condition});"],
    "description": "Do-while loop"
  },
  "If Statement": {
    "prefix": ["if"],
    "body": ["if (${1:condition}) {", "\t${0}", "}"],
    "description": "If statement"
  },
  "If-Else Statement": {
    "prefix": ["ife"],
    "body": ["if (${1:condition}) {", "\t${2}", "} else {", "\t${0}", "}"],
    "description": "If-else statement"
  },
  "Else Statement": {
    "prefix": ["else"],
    "body": ["} else {", "\t${0}", "}"],
    "description": "Else statement"
  },
  "Switch Statement": {
    "prefix": ["switch"],
    "body": ["switch (${1:expr}) {", "\tcase ${2:value}:", "\t\t${0:break;}", "\tdefault:", "\t\tbreak;", "}"],
    "description": "Switch statement"
  },
  "Function Declaration": {
    "prefix": ["function"],
    "body": ["function ${1:name}(${2:params}) {", "\t${0}", "}"],
    "description": "Function declaration"
  },
  "Arrow Function": {
    "prefix": ["arrow", "af"],
    "body": ["const ${1:name} = (${2:params}) => {", "\t${0}", "}"],
    "description": "Arrow function"
  },
  "Async Function": {
    "prefix": ["async"],
    "body": ["async function ${1:name}(${2:params}) {", "\t${0}", "}"],
    "description": "Async function"
  },
  "Async Arrow Function": {
    "prefix": ["asyncarrow", "aaf"],
    "body": ["const ${1:name} = async (${2:params}) => {", "\t${0}", "}"],
    "description": "Async arrow function"
  },
  "Console Log": {
    "prefix": ["log", "clog"],
    "body": ["console.log(${1:value});"],
    "description": "Console log"
  },
  "Console Error": {
    "prefix": ["cerror", "consoleerror"],
    "body": ["console.error(${1:error});"],
    "description": "Console error"
  },
  "Console Warn": {
    "prefix": ["cwarn", "consolewarn"],
    "body": ["console.warn(${1:message});"],
    "description": "Console warning"
  },
  "Const": {
    "prefix": ["const"],
    "body": ["const ${1:name} = ${2:value};"],
    "description": "Const declaration"
  },
  "Let": {
    "prefix": ["let"],
    "body": ["let ${1:name} = ${2:value};"],
    "description": "Let declaration"
  },
  "Var": {
    "prefix": ["var"],
    "body": ["var ${1:name} = ${2:value};"],
    "description": "Var declaration"
  },
  "Class": {
    "prefix": ["class"],
    "body": ["class ${1:ClassName} {", "\tconstructor(${2:params}) {", "\t\t${0}", "\t}", "}"],
    "description": "Class definition"
  },
  "Export Default": {
    "prefix": ["exportdefault", "expd"],
    "body": ["export default ${1:name};"],
    "description": "Export default"
  },
  "Export Named": {
    "prefix": ["export"],
    "body": ["export { ${1:name} };"],
    "description": "Export named"
  },
  "Import": {
    "prefix": ["import"],
    "body": ["import ${1:name} from '${2:module}';"],
    "description": "Import default"
  },
  "Import Named": {
    "prefix": ["importn"],
    "body": ["import { ${1:name} } from '${2:module}';"],
    "description": "Import named"
  },
  "Require": {
    "prefix": ["require"],
    "body": ["const ${1:name} = require('${2:module}');"],
    "description": "Require module"
  },
  "Try-Catch": {
    "prefix": ["try"],
    "body": ["try {", "\t${1}", "} catch (${2:error}) {", "\t${0}", "}"],
    "description": "Try-catch block"
  },
  "New Promise": {
    "prefix": ["promise"],
    "body": ["new Promise((resolve, reject) => {", "\t${0}", "});"],
    "description": "Promise constructor"
  },
  "Then/Catch": {
    "prefix": ["then"],
    "body": [".then((${1:result}) => {", "\t${0}", "})", ".catch((${2:err}) => {", "\tconsole.error(err);", "})"],
    "description": "Promise then/catch chain"
  },
  "SetTimeout": {
    "prefix": ["settimeout", "sto"],
    "body": ["setTimeout(() => {", "\t${0}", "}, ${1:1000});"],
    "description": "Set timeout"
  },
  "SetInterval": {
    "prefix": ["setinterval", "sin"],
    "body": ["setInterval(() => {", "\t${0}", "}, ${1:1000});"],
    "description": "Set interval"
  },
  "AddEventListener": {
    "prefix": ["addeventlistener", "ael"],
    "body": ["${1:element}.addEventListener('${2:click}', (${3:event}) => {", "\t${0}", "});"],
    "description": "Add event listener"
  },
  "Template Literal": {
    "prefix": ["template", "tpl"],
    "body": ["`$${1:value}`"],
    "description": "Template literal"
  },
  "Destructure Object": {
    "prefix": ["destobj", "dobj"],
    "body": ["const { ${1:prop1}, ${2:prop2} } = ${3:obj};"],
    "description": "Object destructuring"
  },
  "Destructure Array": {
    "prefix": ["destarr", "darr"],
    "body": ["const [${1:a}, ${2:b}] = ${3:arr};"],
    "description": "Array destructuring"
  },
  "Spread": {
    "prefix": ["spread"],
    "body": ["...${1:iterable}"],
    "description": "Spread operator"
  },
  "Rest Params": {
    "prefix": ["rest"],
    "body": ["...${1:args}"],
    "description": "Rest parameters"
  },
  "Array.forEach": {
    "prefix": ["foreach"],
    "body": ["${1:array}.forEach((${2:item}) => {", "\t${0}", "});"],
    "description": "Array forEach"
  },
  "Array.map": {
    "prefix": ["map"],
    "body": ["${1:array}.map((${2:item}) => ${3:item})"],
    "description": "Array map"
  },
  "Array.filter": {
    "prefix": ["filter"],
    "body": ["${1:array}.filter((${2:item}) => ${3:condition})"],
    "description": "Array filter"
  },
  "Array.reduce": {
    "prefix": ["reduce"],
    "body": ["${1:array}.reduce((${2:acc}, ${3:val}) => $2 + $3, 0)"],
    "description": "Array reduce"
  },
  "Array.find": {
    "prefix": ["find"],
    "body": ["${1:array}.find((${2:item}) => ${3:condition})"],
    "description": "Array find"
  },
  "Array.includes": {
    "prefix": ["includes"],
    "body": ["${1:array}.includes(${2:value})"],
    "description": "Array includes"
  },
  "String.includes": {
    "prefix": ["strincludes"],
    "body": ["${1:string}.includes(${2:substring})"],
    "description": "String includes"
  },
  "String.startsWith": {
    "prefix": ["startswith", "strsw"],
    "body": ["${1:string}.startsWith(${2:prefix})"],
    "description": "String startsWith"
  },
  "String.endsWith": {
    "prefix": ["endswith", "strew"],
    "body": ["${1:string}.endsWith(${2:suffix})"],
    "description": "String endsWith"
  },
  "JSON Parse": {
    "prefix": ["jsonparse"],
    "body": ["JSON.parse(${1:jsonString})"],
    "description": "JSON parse"
  },
  "JSON Stringify": {
    "prefix": ["jsonstringify", "jsonstr"],
    "body": ["JSON.stringify(${1:obj})"],
    "description": "JSON stringify"
  }
}
