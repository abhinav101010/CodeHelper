{
  "HTML5 Boilerplate": {
    "prefix": ["html", "html5"],
    "body": ["<!DOCTYPE html>", "<html lang=\"${1:en}\">", "<head>", "\t<meta charset=\"UTF-8\">", "\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">", "\t<title>${2:Document}</title>", "</head>", "<body>", "\t${0}", "</body>", "</html>"],
    "description": "HTML5 boilerplate"
  },
  "Script Tag": {
    "prefix": ["script"],
    "body": ["<script>", "\t${0}", "</script>"],
    "description": "Script tag"
  },
  "Script Src": {
    "prefix": ["scripts", "scriptsrc"],
    "body": ["<script src=\"${1:file.js}\"></script>"],
    "description": "External script"
  },
  "Style Tag": {
    "prefix": ["style"],
    "body": ["<style>", "\t${0}", "</style>"],
    "description": "Style tag"
  },
  "Link CSS": {
    "prefix": ["linkcss", "link"],
    "body": ["<link rel=\"stylesheet\" href=\"${1:style.css}\">"],
    "description": "Link CSS"
  },
  "Div": {
    "prefix": ["div"],
    "body": ["<div>${0}</div>"],
    "description": "Div element"
  },
  "Div with Class": {
    "prefix": ["divc", "divclass"],
    "body": ["<div class=\"${1:classname}\">${0}</div>"],
    "description": "Div with class"
  },
  "Span": {
    "prefix": ["span"],
    "body": ["<span>${0}</span>"],
    "description": "Span element"
  },
  "Paragraph": {
    "prefix": ["p"],
    "body": ["<p>${0}</p>"],
    "description": "Paragraph"
  },
  "Anchor": {
    "prefix": ["a", "href"],
    "body": ["<a href=\"${1:url}\">${0}</a>"],
    "description": "Anchor link"
  },
  "Image": {
    "prefix": ["img", "image"],
    "body": ["<img src=\"${1:image.jpg}\" alt=\"${2:description}\">"],
    "description": "Image element"
  },
  "Unordered List": {
    "prefix": ["ul"],
    "body": ["<ul>", "\t<li>${0}</li>", "</ul>"],
    "description": "Unordered list"
  },
  "Ordered List": {
    "prefix": ["ol"],
    "body": ["<ol>", "\t<li>${0}</li>", "</ol>"],
    "description": "Ordered list"
  },
  "List Item": {
    "prefix": ["li"],
    "body": ["<li>${0}</li>"],
    "description": "List item"
  },
  "Header 1": {
    "prefix": ["h1"],
    "body": ["<h1>${0}</h1>"],
    "description": "Heading 1"
  },
  "Header 2": {
    "prefix": ["h2"],
    "body": ["<h2>${0}</h2>"],
    "description": "Heading 2"
  },
  "Header 3": {
    "prefix": ["h3"],
    "body": ["<h3>${0}</h3>"],
    "description": "Heading 3"
  },
  "Header 4": {
    "prefix": ["h4"],
    "body": ["<h4>${0}</h4>"],
    "description": "Heading 4"
  },
  "Header 5": {
    "prefix": ["h5"],
    "body": ["<h5>${0}</h5>"],
    "description": "Heading 5"
  },
  "Header 6": {
    "prefix": ["h6"],
    "body": ["<h6>${0}</h6>"],
    "description": "Heading 6"
  },
  "Form": {
    "prefix": ["form"],
    "body": ["<form action=\"${1:/submit}\" method=\"${2:post}\">", "\t${0}", "</form>"],
    "description": "Form element"
  },
  "Input": {
    "prefix": ["input"],
    "body": ["<input type=\"${1:text}\" name=\"${2:name}\" id=\"${3:id}\">"],
    "description": "Input element"
  },
  "Input with Label": {
    "prefix": ["inputl", "inputlabel"],
    "body": ["<label for=\"${1:id}\">${2:Label}</label>", "<input type=\"${3:text}\" name=\"$1\" id=\"$1\">"],
    "description": "Input with label"
  },
  "Button": {
    "prefix": ["button"],
    "body": ["<button type=\"${1:button}\">${0}</button>"],
    "description": "Button element"
  },
  "Select": {
    "prefix": ["select"],
    "body": ["<select name=\"${1:name}\" id=\"${2:id}\">", "\t<option value=\"${3:value}\">${4:Option}</option>", "</select>"],
    "description": "Select dropdown"
  },
  "Textarea": {
    "prefix": ["textarea"],
    "body": ["<textarea name=\"${1:name}\" id=\"${2:id}\" rows=\"${3:4}\">${0}</textarea>"],
    "description": "Textarea"
  },
  "Table": {
    "prefix": ["table"],
    "body": ["<table>", "\t<thead>", "\t\t<tr>", "\t\t\t<th>${0}</th>", "\t\t</tr>", "\t</thead>", "\t<tbody>", "\t\t<tr>", "\t\t\t<td></td>", "\t\t</tr>", "\t</tbody>", "</table>"],
    "description": "Table structure"
  },
  "Table Row": {
    "prefix": ["tr"],
    "body": ["<tr>", "\t<td>${0}</td>", "</tr>"],
    "description": "Table row"
  },
  "Table Header": {
    "prefix": ["th"],
    "body": ["<th>${0}</th>"],
    "description": "Table header cell"
  },
  "Table Data": {
    "prefix": ["td"],
    "body": ["<td>${0}</td>"],
    "description": "Table data cell"
  },
  "Meta Viewport": {
    "prefix": ["metaview"],
    "body": ["<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">"],
    "description": "Viewport meta"
  },
  "Meta Charset": {
    "prefix": ["metacharset"],
    "body": ["<meta charset=\"UTF-8\">"],
    "description": "Charset meta"
  },
  "Meta Description": {
    "prefix": ["metadesc"],
    "body": ["<meta name=\"description\" content=\"${1:description}\">"],
    "description": "Description meta"
  },
  "Nav": {
    "prefix": ["nav"],
    "body": ["<nav>", "\t<ul>", "\t\t<li><a href=\"${1:#}\">${2:Link}</a></li>", "\t</ul>", "</nav>"],
    "description": "Navigation"
  },
  "Header Tag": {
    "prefix": ["header"],
    "body": ["<header>", "\t${0}", "</header>"],
    "description": "Header element"
  },
  "Footer": {
    "prefix": ["footer"],
    "body": ["<footer>", "\t${0}", "</footer>"],
    "description": "Footer element"
  },
  "Section": {
    "prefix": ["section"],
    "body": ["<section>", "\t${0}", "</section>"],
    "description": "Section element"
  },
  "Article": {
    "prefix": ["article"],
    "body": ["<article>", "\t${0}", "</article>"],
    "description": "Article element"
  },
  "Aside": {
    "prefix": ["aside"],
    "body": ["<aside>", "\t${0}", "</aside>"],
    "description": "Aside element"
  },
  "Main": {
    "prefix": ["main"],
    "body": ["<main>", "\t${0}", "</main>"],
    "description": "Main element"
  },
  "Figure": {
    "prefix": ["figure"],
    "body": ["<figure>", "\t<img src=\"${1:image.jpg}\" alt=\"${2:alt}\">", "\t<figcaption>${3:Caption}</figcaption>", "</figure>"],
    "description": "Figure with caption"
  },
  "Video": {
    "prefix": ["video"],
    "body": ["<video src=\"${1:video.mp4}\" controls></video>"],
    "description": "Video element"
  },
  "Audio": {
    "prefix": ["audio"],
    "body": ["<audio src=\"${1:audio.mp3}\" controls></audio>"],
    "description": "Audio element"
  },
  "Canvas": {
    "prefix": ["canvas"],
    "body": ["<canvas id=\"${1:myCanvas}\" width=\"${2:300}\" height=\"${3:200}\"></canvas>"],
    "description": "Canvas element"
  },
  "Details/Summary": {
    "prefix": ["details"],
    "body": ["<details>", "\t<summary>${1:Title}</summary>", "\t${0}", "</details>"],
    "description": "Details/Summary"
  }
}
